{
  "name": "@pignal/templates",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./resolved": "./src/_resolved.ts",
    "./all-configs": "./src/all-configs.ts",
    "./registry": "./src/template-registry.ts",
    "./seeds/*": "./seeds/*",
    "./*": "./src/*/index.tsx"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "check-all": "pnpm type-check",
    "template:create": "tsx scripts/create-template.ts",
    "seed:generate": "tsx scripts/generate-seed.ts",
    "resolve-template": "tsx scripts/resolve-template.ts"
  },
  "dependencies": {
    "@pignal/core": "workspace:*",
    "@pignal/db": "workspace:*",
    "@pignal/render": "workspace:*",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
