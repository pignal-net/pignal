{
  "name": "@pignal/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --persist-to .wrangler-state",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply pignal-server-db --local --persist-to .wrangler-state",
    "db:migrate:prod": "wrangler d1 migrations apply pignal-server-db --remote",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check-all": "pnpm type-check && pnpm lint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@pignal/core": "workspace:*",
    "@pignal/db": "workspace:*",
    "@pignal/web": "workspace:*",
    "agents": "^0.0.76",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.34.0",
    "wrangler": "^3.91.0"
  }
}
